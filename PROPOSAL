## 10. Suggested Manifest

```json
{
  "manifest_version": 3,
  "name": "ChatGPT Markdown Exporter",
  "version": "0.1.0",
  "description": "Export the current ChatGPT conversation into Markdown with local assets.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "action": {
    "default_title": "Export ChatGPT Conversation",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "serviceWorker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
```

