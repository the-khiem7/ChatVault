## 11. Data Model

### 11.1 Conversation

```ts
export type ConversationExport = {
  title: string;
  slug: string;
  sourceUrl: string;
  exportedAt: string;
  messages: ChatMessage[];
  assets: ExportAsset[];
};
```

### 11.2 Message

```ts
export type ChatMessage = {
  index: number;
  role: "user" | "assistant" | "system" | "unknown";
  blocks: ContentBlock[];
};
```

### 11.3 Content Block

```ts
export type ContentBlock =
  | ParagraphBlock
  | HeadingBlock
  | ListBlock
  | CodeBlock
  | TableBlock
  | QuoteBlock
  | MathBlock
  | ImageBlock
  | AttachmentBlock
  | UnknownBlock;
```

### 11.4 Asset

```ts
export type ExportAsset = {
  id: string;
  type: "image" | "file";
  sourceUrl: string;
  localPath: string;
  mimeType?: string;
  extension?: string;
};
```

